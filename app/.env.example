# Session signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_string

# Token lifetime (default 7d)
TOKEN_TTL=7d

# Password hashes — generate with: npm run hash -- 'your-password'
PW_COACH_A=
PW_COACH_B=
PW_COACH_C=
PW_COACH_D=
PW_ADMIN=

# Apps Script deployment URL (the /exec URL)
HQ_APPSCRIPT_URL=
# Shared token (must match SCRIPT_TOKEN in Apps Script properties)
HQ_TOKEN=

# GitHub — for dispatching PDF generation workflow
GH_TOKEN=
GH_REPO=czaramit/MaidanfitnessCard
